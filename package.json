{
  "name": "personal-finance-dashboard",
  "private": true,
  "version": "1.0.0",
  "description": "Premium Personal Finance Dashboard",
  "author": "FinancePro Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/MurtazaJ53/finance-dashboard.git"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build:vite": "vite build",
    "build:main": "esbuild main-process/main.ts --bundle --platform=node --external:electron --external:better-sqlite3 --external:electron-updater --external:googleapis --outfile=dist-electron/main.js",
    "build:preload": "esbuild main-process/preload.ts --bundle --platform=node --external:electron --outfile=dist-electron/preload.js",
    "build:electron": "npm run build:main && npm run build:preload",
    "build": "npm run build:vite && npm run build:electron && electron-builder",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && npm run build:electron && node launch.js\""
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "better-sqlite3": "^12.6.2",
    "chart.js": "^4.5.1",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.34.3",
    "googleapis": "^171.4.0",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.575.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.4",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.2.4",
    "reflect-metadata": "^0.2.2",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^32.0.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.3",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.financepro.app",
    "productName": "FinancePro",
    "publish": [
      {
        "provider": "github",
        "owner": "MurtazaJ53",
        "repo": "finance-dashboard"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*",
      "node_modules/googleapis/**/*",
      "node_modules/google-auth-library/**/*",
      "node_modules/gaxios/**/*",
      "node_modules/gcp-metadata/**/*",
      "node_modules/gtoken/**/*",
      "node_modules/jws/**/*",
      "node_modules/electron-updater/**/*",
      "node_modules/builder-util-runtime/**/*"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "msi",
        "portable"
      ]
    },
    "msi": {
      "oneClick": false,
      "shortcutName": "FinancePro",
      "runAfterFinish": true
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}